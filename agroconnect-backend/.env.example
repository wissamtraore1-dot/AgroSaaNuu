# ═══════════════════════════════════════════════════════════
#  AgroSaaNuu — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# ═══════════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────────
SECRET_KEY=changez-moi-en-production-clé-longue-et-aléatoire
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données ──────────────────────────────────────────
# SQLite (développement)
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (production)
# DATABASE_URL=postgres://user:password@localhost:5432/agrosaanuu

# ── Redis (cache + Celery) ───────────────────────────────────
# Windows dev : installer Redis via WSL ou Docker
# docker run -d -p 6379:6379 redis:alpine
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── SMS — Africa's Talking ───────────────────────────────────
# https://africastalking.com/ → Sandbox gratuit
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_SANDBOX=True

# ── Paiement — FedaPay (Mobile Money Bénin) ──────────────────
# https://fedapay.com/ → Sandbox gratuit
FEDAPAY_SECRET_KEY=
FEDAPAY_SANDBOX=True

# ── Stockage images — Cloudinary ────────────────────────────
# https://cloudinary.com/ → Plan gratuit (25 GB)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Gmail SMTP) ───────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=AgroSaaNuu <noreply@agrosaanuu.com>

# ── Twilio (SMS fallback) ────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
