# ════════════════════════════════════════════════════════════════
# AGROSAANUU — .gitignore
# ════════════════════════════════════════════════════════════════

# ── Python / Django ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.pdb

# Environnements virtuels
venv/
env/
.venv/
ENV/
.env/

# Variables d'environnement (JAMAIS committer le .env)
.env
.env.*
!.env.example

# Base de données locale
*.sqlite3
db.sqlite3

# Fichiers uploadés (media) + statiques compilés
media/
staticfiles/
uploads/

# Logs
*.log
logs/
vite-dev.log
vite-direct.log
pip-log.txt

# Tests / couverture
.coverage
htmlcov/
.pytest_cache/
.tox/
coverage.xml
*.cover

# Oeufs / distributions Python
*.egg-info/
*.egg
dist/
build/
*.whl

# Celery
celerybeat-schedule
celerybeat-schedule.db
celerybeat.pid
celerybeat.db

# Fichiers PID (Gunicorn, uWSGI, etc.)
*.pid
gunicorn.pid

# Redis
dump.rdb
redis-data/
*.rdb

# Cloudinary / stockage cloud (clés locales)
cloudinary.env
.cloudinary

# Certificats SSL
*.pem
*.key
*.crt
*.p12
secrets/
credentials/

# Pyenv / Python version
.python-version
# ... sauf celui du backend, lu par Render pour épingler la version Python en déploiement
!agroconnect-backend/.python-version

# direnv
.envrc

# Fichiers de traduction compilés Django
*.mo

# mypy / type checking
.mypy_cache/
.dmypy.json
dmypy.json

# rope (refactoring Python)
.ropeproject/

# Profiling
*.prof

# ── Node / React / Vite ───────────────────────────────────────────────────────
node_modules/
dist/
build/
dist-ssr/
.vite/

# Vite env locaux
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env*
!frontend/.env.example

# Logs npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Cache npm
.npm/
.yarn/

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
__MACOSX/

# ── Divers ─────────────────────────────────────────────────────────────────────
*.local
*.bak
*.tmp
*.temp
*.orig
.cache/
tmp/
